{
  "meta": {
    "title": "Computer science, from physics to patterns",
    "reading": "Left to right: physical truths → math/information → hardware → systems software → program theory → distributed systems → languages → patterns & practice. Every edge is a 'therefore'.",
    "version": 1
  },
  "nodes": [
    { "id": "light-speed", "Label": { "text": "Speed of light is finite" }, "NodeType": "circle", "Position": { "x": 0, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "~30cm per nanosecond. Same rack ≈ µs, cross-continent ≈ 100ms round trip. Every latency budget bottoms out here." },
    { "id": "thermo-2", "Label": { "text": "Entropy grows (2nd law)" }, "NodeType": "circle", "Position": { "x": 0, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "Order costs energy; decay is the default. Bit rot, leaks, drift — maintenance is physics, not failure." },
    { "id": "landauer", "Label": { "text": "Landauer's principle" }, "NodeType": "circle", "Position": { "x": 0, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "Erasing one bit costs at least kT·ln2 of energy. Computation has a physical price floor." },
    { "id": "quantum", "Label": { "text": "Matter is quantized" }, "NodeType": "circle", "Position": { "x": 0, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "Band gaps let semiconductors switch; tunneling caps how small a transistor can get (~nm)." },
    { "id": "locality", "Label": { "text": "No action at a distance" }, "NodeType": "circle", "Position": { "x": 0, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "State must physically travel. There is no global 'now' — only messages arriving late." },
    { "id": "noise", "Label": { "text": "All channels are noisy" }, "NodeType": "circle", "Position": { "x": 0, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "Thermal noise is everywhere. Reliable systems are always built from unreliable parts." },
    { "id": "energy-heat", "Label": { "text": "Switching dissipates heat" }, "NodeType": "circle", "Position": { "x": 0, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "Power ∝ frequency·V². Clocks hit the heat wall (~2005) → the multicore/GPU era." },

    { "id": "shannon", "Label": { "text": "Shannon entropy" }, "NodeType": "square", "Position": { "x": 400, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "Information = surprise, measured in bits. The entropy of the source is the compression floor." },
    { "id": "channel-capacity", "Label": { "text": "Channel capacity" }, "NodeType": "square", "Position": { "x": 400, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "A noisy channel still has an exact maximum reliable bit rate. Bandwidth is a theorem." },
    { "id": "error-correction", "Label": { "text": "Error-correcting codes" }, "NodeType": "square", "Position": { "x": 400, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "Redundancy buys reliability: ECC RAM, RAID, TCP checksums, Reed-Solomon in QR codes and SSDs." },
    { "id": "boolean", "Label": { "text": "Boolean algebra" }, "NodeType": "square", "Position": { "x": 400, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "true/false with AND/OR/NOT is enough to express any computable decision." },
    { "id": "turing", "Label": { "text": "Turing machine" }, "NodeType": "square", "Position": { "x": 400, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "Tape + head + rule table = universal computation. Your laptop is one, faster." },
    { "id": "lambda", "Label": { "text": "Lambda calculus" }, "NodeType": "square", "Position": { "x": 400, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "Functions all the way down; equivalent in power to Turing machines (Church–Turing thesis)." },
    { "id": "computability", "Label": { "text": "Halting problem" }, "NodeType": "square", "Position": { "x": 400, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "Some questions no program can ever answer. All static analysis is forever an approximation." },
    { "id": "complexity", "Label": { "text": "Complexity: P vs NP" }, "NodeType": "square", "Position": { "x": 400, "y": 1290 }, "Size": { "w": 260, "h": 120 }, "Description": "Some 'easy to verify' problems have no known fast solution. Cryptography banks on that gap." },
    { "id": "info-physical", "Label": { "text": "Information is physical" }, "NodeType": "square", "Position": { "x": 400, "y": 1460 }, "Size": { "w": 260, "h": 120 }, "Description": "Bits live on electrons, magnetic domains, photons. There is no software without hardware." },
    { "id": "queueing", "Label": { "text": "Queueing theory" }, "NodeType": "square", "Position": { "x": 400, "y": 1630 }, "Size": { "w": 260, "h": 120 }, "Description": "As utilization → 100%, wait time → ∞. Why mature systems cap load around 70–80%." },
    { "id": "graph-theory", "Label": { "text": "Graph theory" }, "NodeType": "square", "Position": { "x": 400, "y": 1800 }, "Size": { "w": 260, "h": 120 }, "Description": "Nodes + edges model networks, dependencies, social systems — and this very map." },
    { "id": "probability", "Label": { "text": "Probability theory" }, "NodeType": "square", "Position": { "x": 400, "y": 1970 }, "Size": { "w": 260, "h": 120 }, "Description": "Tail latencies, failure odds, hash collisions — production reasoning is p(x) reasoning." },

    { "id": "transistor", "Label": { "text": "Transistor" }, "NodeType": "text", "Position": { "x": 800, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "A voltage-controlled switch. ~10¹⁰ per chip, each one a quantum-physics experiment that works." },
    { "id": "gate", "Label": { "text": "Logic gates" }, "NodeType": "text", "Position": { "x": 800, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "NAND is universal — any circuit, any computer, from one gate type repeated." },
    { "id": "clock", "Label": { "text": "Clock & sync logic" }, "NodeType": "text", "Position": { "x": 800, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "A global heartbeat makes state changes discrete. GHz = 10⁹ decisions per second." },
    { "id": "cpu", "Label": { "text": "CPU (von Neumann)" }, "NodeType": "text", "Position": { "x": 800, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "Fetch–decode–execute over one memory holding both code and data." },
    { "id": "von-neumann-bottleneck", "Label": { "text": "Von Neumann bottleneck" }, "NodeType": "text", "Position": { "x": 800, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "The CPU starves waiting on memory. Most architecture since is a workaround for this." },
    { "id": "memory-hierarchy", "Label": { "text": "Memory hierarchy" }, "NodeType": "text", "Position": { "x": 800, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "Register 1ns → L1 4ns → RAM 100ns → SSD 100µs → network ms. Distance is time, literally." },
    { "id": "cache-hw", "Label": { "text": "Caching" }, "NodeType": "cache", "Position": { "x": 800, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "Keep hot data close. Works only because programs repeat themselves (locality of reference)." },
    { "id": "speculation", "Label": { "text": "Speculative execution" }, "NodeType": "text", "Position": { "x": 800, "y": 1290 }, "Size": { "w": 260, "h": 120 }, "Description": "Guess the branch, run ahead, roll back if wrong. Also the root of Spectre — speed leaks secrets." },
    { "id": "simd-parallel", "Label": { "text": "Parallel silicon (SIMD/GPU)" }, "NodeType": "text", "Position": { "x": 800, "y": 1460 }, "Size": { "w": 260, "h": 120 }, "Description": "Can't clock faster → go wider. GPUs: thousands of simple cores doing the same op on different data." },
    { "id": "amdahl", "Label": { "text": "Amdahl's law" }, "NodeType": "text", "Position": { "x": 800, "y": 1630 }, "Size": { "w": 260, "h": 120 }, "Description": "Speedup is capped by the serial fraction: 5% serial code means at most 20×, ever." },

    { "id": "os", "Label": { "text": "Operating system" }, "NodeType": "text", "Position": { "x": 1200, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "Multiplexes one machine into many illusions: processes, files, sockets, users." },
    { "id": "process-thread", "Label": { "text": "Processes & threads" }, "NodeType": "text", "Position": { "x": 1200, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "Isolation vs sharing. Threads share a heap — cheap to spawn, easy to corrupt." },
    { "id": "scheduling", "Label": { "text": "Scheduling" }, "NodeType": "text", "Position": { "x": 1200, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "Who runs next. Preemption buys fairness at the price of context-switch overhead." },
    { "id": "virtual-memory", "Label": { "text": "Virtual memory" }, "NodeType": "text", "Position": { "x": 1200, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "Every process dreams it owns the machine; page tables and the TLB make it true enough." },
    { "id": "gc", "Label": { "text": "Garbage collection" }, "NodeType": "text", "Position": { "x": 1200, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "Automated fight against memory entropy. Pauses are the tax; ownership systems prepay it." },
    { "id": "filesystem", "Label": { "text": "File systems" }, "NodeType": "text", "Position": { "x": 1200, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "Blocks → files + directories. Journaling = crash consistency via write-ahead discipline." },
    { "id": "net-stack", "Label": { "text": "Network stack (IP)" }, "NodeType": "text", "Position": { "x": 1200, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "Packets, best-effort, layered. Each layer politely lies to the one above it." },
    { "id": "tcp", "Label": { "text": "TCP: reliable delivery" }, "NodeType": "text", "Position": { "x": 1200, "y": 1290 }, "Size": { "w": 260, "h": 120 }, "Description": "Retransmission + ordering + flow control on top of chaos. Head-of-line blocking is the price." },
    { "id": "dns", "Label": { "text": "Naming (DNS)" }, "NodeType": "gateway", "Position": { "x": 1200, "y": 1460 }, "Size": { "w": 260, "h": 120 }, "Description": "Names → addresses, cached with TTLs at every layer. 'It's always DNS.'" },
    { "id": "crypto", "Label": { "text": "Cryptography" }, "NodeType": "text", "Position": { "x": 1200, "y": 1630 }, "Size": { "w": 260, "h": 120 }, "Description": "One-way functions: easy forward, infeasible backward. Trust built from math, not promises." },

    { "id": "ds", "Label": { "text": "Data structures" }, "NodeType": "text", "Position": { "x": 1600, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "Shape data for the questions you'll ask. Array vs map vs tree = a bet on access patterns." },
    { "id": "big-o", "Label": { "text": "Asymptotic complexity" }, "NodeType": "text", "Position": { "x": 1600, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "O(n log n) beats O(n²) eventually — and 'eventually' arrives sooner than you think." },
    { "id": "hashing", "Label": { "text": "Hashing" }, "NodeType": "text", "Position": { "x": 1600, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "Uniform scatter → O(1) lookup, dedup, sharding, integrity checks, load balancing." },
    { "id": "trees-indexes", "Label": { "text": "Trees & indexes" }, "NodeType": "index", "Position": { "x": 1600, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "log(n) is the workhorse: B-trees inside every database, LSM trees under every write-heavy store." },
    { "id": "state-machine", "Label": { "text": "State machines" }, "NodeType": "text", "Position": { "x": 1600, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "Explicit states + transitions. Model protocols, parsers, and UIs as FSMs and bug classes vanish." },
    { "id": "invariants", "Label": { "text": "Invariants & contracts" }, "NodeType": "text", "Position": { "x": 1600, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "What stays true no matter what happens. The real spec — tests only sample it." },
    { "id": "types", "Label": { "text": "Type systems" }, "NodeType": "text", "Position": { "x": 1600, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "Proofs the compiler checks for free. Make illegal states unrepresentable." },
    { "id": "immutability", "Label": { "text": "Immutability" }, "NodeType": "text", "Position": { "x": 1600, "y": 1290 }, "Size": { "w": 260, "h": 120 }, "Description": "Data that can't change can't race, can't corrupt, and caches forever." },
    { "id": "concurrency-theory", "Label": { "text": "Concurrency & races" }, "NodeType": "text", "Position": { "x": 1600, "y": 1460 }, "Size": { "w": 260, "h": 120 }, "Description": "Interleavings explode combinatorially. Share nothing, or lock, or serialize — pick one honestly." },
    { "id": "recursion", "Label": { "text": "Recursion & induction" }, "NodeType": "text", "Position": { "x": 1600, "y": 1630 }, "Size": { "w": 260, "h": 120 }, "Description": "Self-similar problems: define the base case and the step. Trees walk themselves." },
    { "id": "data-oriented", "Label": { "text": "Data-oriented design / ECS" }, "NodeType": "text", "Position": { "x": 1600, "y": 1800 }, "Size": { "w": 260, "h": 120 }, "Description": "Lay data out for the cache, not the class taxonomy. Struct-of-arrays + systems — games, and this editor." },

    { "id": "cap", "Label": { "text": "CAP theorem" }, "NodeType": "text", "Position": { "x": 2000, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "Partitions happen (physics). Then choose: stale-but-available or correct-but-down." },
    { "id": "consensus", "Label": { "text": "Consensus (Raft/Paxos)" }, "NodeType": "text", "Position": { "x": 2000, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "Agreement over lossy links via majority quorums. Slow because light is slow." },
    { "id": "replication", "Label": { "text": "Replication" }, "NodeType": "text", "Position": { "x": 2000, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "Copies buy read throughput and survival. Sync costs latency; async opens a divergence window." },
    { "id": "sharding", "Label": { "text": "Sharding / partitioning" }, "NodeType": "text", "Position": { "x": 2000, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "Split data by key to scale writes. Cross-shard queries and transactions are where dreams die." },
    { "id": "queue-async", "Label": { "text": "Queues & async messaging" }, "NodeType": "kafka", "Position": { "x": 2000, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "Decouple producer from consumer. The buffer absorbs bursts and sells you staleness in return." },
    { "id": "backpressure", "Label": { "text": "Backpressure" }, "NodeType": "text", "Position": { "x": 2000, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "A slow consumer must slow the producer, or memory dies. Push the signal upstream." },
    { "id": "idempotency", "Label": { "text": "Idempotency" }, "NodeType": "text", "Position": { "x": 2000, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "Retries duplicate work. f(f(x)) = f(x) is what makes at-least-once delivery safe." },
    { "id": "cache-dist", "Label": { "text": "Distributed caching" }, "NodeType": "cache", "Position": { "x": 2000, "y": 1290 }, "Size": { "w": 260, "h": 120 }, "Description": "Invalidation is one of the two hard things. TTL vs event-driven invalidation is the core tradeoff." },
    { "id": "circuit-breaker-c", "Label": { "text": "Circuit breaker" }, "NodeType": "circuit-breaker", "Position": { "x": 2000, "y": 1460 }, "Size": { "w": 260, "h": 120 }, "Description": "Fail fast while a dependency is sick — stops retry storms from cascading the outage." },
    { "id": "retry", "Label": { "text": "Retry + jitter + timeout" }, "NodeType": "text", "Position": { "x": 2000, "y": 1630 }, "Size": { "w": 260, "h": 120 }, "Description": "Every remote call fails sometimes. Budget it: your timeout must be shorter than your caller's." },
    { "id": "microservices", "Label": { "text": "Microservices" }, "NodeType": "service", "Position": { "x": 2000, "y": 1800 }, "Size": { "w": 260, "h": 120 }, "Description": "Team autonomy bought with a distributed-systems tax. The network is now inside your app." },
    { "id": "observability", "Label": { "text": "Observability" }, "NodeType": "text", "Position": { "x": 2000, "y": 1970 }, "Size": { "w": 260, "h": 120 }, "Description": "Logs, metrics, traces — the only senses you have in production. Unobserved state doesn't exist." },
    { "id": "eventual", "Label": { "text": "Eventual consistency" }, "NodeType": "text", "Position": { "x": 2000, "y": 2140 }, "Size": { "w": 260, "h": 120 }, "Description": "Converges when traffic quiets. The UI must render 'not yet' honestly." },
    { "id": "wal", "Label": { "text": "Write-ahead log" }, "NodeType": "text", "Position": { "x": 2000, "y": 2310 }, "Size": { "w": 260, "h": 120 }, "Description": "Append first, apply later. The primitive under databases, Kafka, and replication alike." },
    { "id": "db-tx", "Label": { "text": "Transactions & ACID" }, "NodeType": "database", "Position": { "x": 2000, "y": 2480 }, "Size": { "w": 260, "h": 120 }, "Description": "All-or-nothing state transitions. Isolation levels are concurrency dials, not magic." },

    { "id": "imperative", "Label": { "text": "Imperative programming" }, "NodeType": "text", "Position": { "x": 2400, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "Mutating steps in sequence — the machine's native dialect (C, Go)." },
    { "id": "fp", "Label": { "text": "Functional programming" }, "NodeType": "text", "Position": { "x": 2400, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "Values in, values out. Referential transparency = you can reason locally." },
    { "id": "oop", "Label": { "text": "Object orientation" }, "NodeType": "text", "Position": { "x": 2400, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "State + behavior behind an interface. The best part was always the message, not the class." },
    { "id": "actors", "Label": { "text": "Actors / CSP" }, "NodeType": "text", "Position": { "x": 2400, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "Share nothing, send messages: Erlang, Go channels. Concurrency without shared-memory locks." },
    { "id": "declarative", "Label": { "text": "Declarative / SQL" }, "NodeType": "text", "Position": { "x": 2400, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "Say what, not how — a planner picks the how. Optimizers beat hand-rolled loops." },
    { "id": "event-loop", "Label": { "text": "Event loop (JS)" }, "NodeType": "text", "Position": { "x": 2400, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "One thread + a queue: no data races, but nothing may block. This app runs on it." },
    { "id": "ownership", "Label": { "text": "Ownership (Rust)" }, "NodeType": "text", "Position": { "x": 2400, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "Memory safety proven at compile time. GC pauses traded for borrow-checker arguments." },
    { "id": "memory-model", "Label": { "text": "Memory models" }, "NodeType": "text", "Position": { "x": 2400, "y": 1290 }, "Size": { "w": 260, "h": 120 }, "Description": "Compilers and CPUs reorder your code. Between threads, happens-before is the only truth." },
    { "id": "metaprog", "Label": { "text": "Metaprogramming" }, "NodeType": "text", "Position": { "x": 2400, "y": 1460 }, "Size": { "w": 260, "h": 120 }, "Description": "Code that writes code: macros, codegen, decorators. Power tool; mind the sharp edges." },

    { "id": "pubsub", "Label": { "text": "Pub/Sub & event bus" }, "NodeType": "text", "Position": { "x": 2800, "y": 100 }, "Size": { "w": 260, "h": 120 }, "Description": "Emitters don't know listeners. This app's spine: past-tense facts drive every redraw." },
    { "id": "observer", "Label": { "text": "Observer pattern" }, "NodeType": "text", "Position": { "x": 2800, "y": 270 }, "Size": { "w": 260, "h": 120 }, "Description": "GoF ancestor of every reactive UI: subscribe, notify — and unsubscribe, or leak." },
    { "id": "strategy", "Label": { "text": "Strategy / DI" }, "NodeType": "text", "Position": { "x": 2800, "y": 440 }, "Size": { "w": 260, "h": 120 }, "Description": "Swap the algorithm behind an interface. Testability is just injectable seams." },
    { "id": "factory-pat", "Label": { "text": "Factory & builder" }, "NodeType": "text", "Position": { "x": 2800, "y": 610 }, "Size": { "w": 260, "h": 120 }, "Description": "Construction as a named seam — one place to intercept, instrument, or fake creation." },
    { "id": "adapter", "Label": { "text": "Adapter / facade" }, "NodeType": "text", "Position": { "x": 2800, "y": 780 }, "Size": { "w": 260, "h": 120 }, "Description": "Wrap the ugly thing. An anti-corruption layer between you and every SDK you didn't write." },
    { "id": "es", "Label": { "text": "Event sourcing" }, "NodeType": "text", "Position": { "x": 2800, "y": 950 }, "Size": { "w": 260, "h": 120 }, "Description": "Store the facts, derive the state. Undo, audit, and replay fall out for free — this repo's sim.record." },
    { "id": "cqrs", "Label": { "text": "CQRS / projections" }, "NodeType": "text", "Position": { "x": 2800, "y": 1120 }, "Size": { "w": 260, "h": 120 }, "Description": "One write model, many read views. Same events, different projections — swappable on the fly." },
    { "id": "saga", "Label": { "text": "Saga / compensation" }, "NodeType": "text", "Position": { "x": 2800, "y": 1290 }, "Size": { "w": 260, "h": 120 }, "Description": "Distributed transactions without 2PC: do the step, and always know how to undo it." },
    { "id": "tdd", "Label": { "text": "TDD & red-green" }, "NodeType": "text", "Position": { "x": 2800, "y": 1460 }, "Size": { "w": 260, "h": 120 }, "Description": "A failing test first is a spec you can execute. Keep the suite fast or it won't be run." },
    { "id": "testing-pyramid", "Label": { "text": "Testing pyramid" }, "NodeType": "text", "Position": { "x": 2800, "y": 1630 }, "Size": { "w": 260, "h": 120 }, "Description": "Many fast unit tests, some integration, few E2E. Invert it and CI becomes a bonfire." },
    { "id": "twelve-factor", "Label": { "text": "12-factor / config" }, "NodeType": "text", "Position": { "x": 2800, "y": 1800 }, "Size": { "w": 260, "h": 120 }, "Description": "Env-injected config, stateless processes, logs as streams — the shape that deploys anywhere." },
    { "id": "semver-api", "Label": { "text": "API contracts & versioning" }, "NodeType": "text", "Position": { "x": 2800, "y": 1970 }, "Size": { "w": 260, "h": 120 }, "Description": "Interfaces are promises. Breaking one is a distributed refactor across code you cannot see." },
    { "id": "least-priv", "Label": { "text": "Least privilege" }, "NodeType": "text", "Position": { "x": 2800, "y": 2140 }, "Size": { "w": 260, "h": 120 }, "Description": "Assume breach. Grant capabilities, not ambient authority; the blast radius is the design." },
    { "id": "ci-cd", "Label": { "text": "CI/CD & releases" }, "NodeType": "text", "Position": { "x": 2800, "y": 2310 }, "Size": { "w": 260, "h": 120 }, "Description": "Small reversible steps beat big-bang launches. Only releases make progress real." }
  ],
